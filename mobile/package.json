{
  "name": "hermes-mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hermes Journal local-first mobile trading journal",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "preview": "vite preview --host 127.0.0.1",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "ios:add": "npm run build && cap add ios --packagemanager CocoaPods",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "cap open ios"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "8.1.0",
    "@capacitor/core": "8.4.1",
    "@capacitor/ios": "8.4.1"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.1",
    "@playwright/test": "1.61.1",
    "@types/sql.js": "1.4.11",
    "sql.js": "1.14.1",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
