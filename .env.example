# Hermes environment — copy to .env and fill in your own values.
# Every credential lives here. Nothing in the repo, config, or database
# should ever contain a secret, a personal path, or a dollar figure.

# ── Market data: Alpaca (default provider) ─────────────────────────────
# Free account at https://alpaca.markets — a paper-trading account is enough;
# no funding required. These are DATA keys; Hermes never places orders.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# ── Market data: Databento (optional fallback provider) ────────────────
# https://databento.com — only needed if you set provider = "databento".
DATABENTO_API_KEY=

# ── AI inference (optional) ─────────────────────────────────────────────
# Local-first: Hermes talks to your own Ollama at OLLAMA_URL (config file).
# A cloud key is only used by tasks you explicitly opt into via config.
ANTHROPIC_API_KEY=

# ── Paths (optional overrides; defaults are relative to the working dir) ─
# HERMES_DATA_DIR=./data
# HERMES_LOG_DIR=./logs
# HERMES_CONFIG=./config/hermes.toml

# ── Server (optional overrides) ─────────────────────────────────────────
# HERMES_HOST=127.0.0.1
# HERMES_PORT=8642
