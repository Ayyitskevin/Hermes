# Hermes environment — copy to .env and fill in your own values.
# Every credential lives here. Nothing in the repo, config, or database
# should ever contain a secret, a personal path, or a dollar figure.

# ── Market data: Alpaca (recommended provider; built-in default is the
#    zero-key "sample" tape until you configure alpaca in hermes.toml) ──
# Free account at https://alpaca.markets — a paper-trading account is enough;
# no funding required. Hermes only ever sends these keys to the DATA host
# (data.alpaca.markets), GET-only — but note Alpaca keys are account-wide,
# not read-scoped, so guard your .env like the credential it is.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# ── Market data: Databento (optional fallback provider) ────────────────
# https://databento.com — only needed if you set provider = "databento".
DATABENTO_API_KEY=

# ── AI inference (optional) ─────────────────────────────────────────────
# Local-first: Hermes talks to your own Ollama at ai.ollama_url (set in
# config/hermes.toml). The cloud key below is the DELIBERATE EXCEPTION —
# used only when you set ai.allow_cloud = true in config/hermes.toml. It is
# read from the environment only, sent only to the Anthropic messages host
# (api.anthropic.com), and the AI layer is data-in/prose-out: it never sees
# or emits an order.
ANTHROPIC_API_KEY=

# ── Paths (optional overrides; defaults are relative to the working dir) ─
# HERMES_DATA_DIR=./data
# HERMES_LOG_DIR=./logs
# HERMES_CONFIG=./config/hermes.toml

# ── Server (optional overrides) ─────────────────────────────────────────
# HERMES_HOST=127.0.0.1
# HERMES_PORT=8642
